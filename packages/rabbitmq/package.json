{
  "name": "@vorq/rabbitmq",
  "version": "0.1.1",
  "description": "RabbitMQ transport adapter for Vorq",
  "type": "module",
  "main": "./dist/index.cjs",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "import": {
        "types": "./dist/index.d.ts",
        "default": "./dist/index.js"
      },
      "require": {
        "types": "./dist/index.d.cts",
        "default": "./dist/index.cjs"
      }
    }
  },
  "files": ["dist"],
  "scripts": {
    "build": "tsup",
    "test": "vitest run",
    "test:watch": "vitest",
    "clean": "rm -rf dist"
  },
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/baccaraaa/vorq",
    "directory": "packages/rabbitmq"
  },
  "publishConfig": {
    "access": "public"
  },
  "dependencies": {
    "amqplib": "0.10.5"
  },
  "devDependencies": {
    "@types/amqplib": "0.10.6"
  },
  "peerDependencies": {
    "@vorq/core": "^0.1.0"
  }
}
